# Rename this file to .env and fill in your real values

PORT=3000

# Shared secret you make up yourself, used to verify webhook setup in Meta dashboard
VERIFY_TOKEN=my_super_secret_verify_token

# ---- WhatsApp Cloud API (business.facebook.com > WhatsApp > API Setup) ----
WHATSAPP_TOKEN=your_whatsapp_permanent_or_temp_access_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ---- Instagram Graph API (via a connected Facebook Page + Meta App) ----
INSTAGRAM_TOKEN=your_instagram_page_access_token
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id
